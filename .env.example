# OpenAI API key for LLM calls
OPENAI_API_KEY=sk-...

# Tavily API key for web search
TAVILY_API_KEY=tvly-...

# Couchbase connection details
COUCHBASE_HOST=localhost
COUCHBASE_USER=Administrator
COUCHBASE_PASSWORD=password
COUCHBASE_BUCKET=agentmem

# AgentMem server URL
AGENTMEM_BASE_URL=http://localhost:8080

# OpenAI model for all agents (optional — defaults to gpt-4o-mini)
MODEL=gpt-4o-mini
